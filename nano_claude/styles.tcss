#main-panels {
    height: 1fr;
}

#file-tree {
    width: 1fr;
    min-width: 15;
}

#editor {
    width: 3.3fr;
    min-width: 20;
}

#chat {
    width: 2.3fr;
    min-width: 20;
}

#code-editor {
    width: 1fr;
    height: 1fr;
}

.hidden {
    display: none;
}

#claude-loading, #claude-not-found, #claude-exited {
    width: 1fr;
    height: 1fr;
    content-align: center middle;
    text-align: center;
    color: $text-muted;
    padding: 2 4;
}

#claude-terminal {
    width: 1fr;
    height: 1fr;
}

#diff-view {
    width: 1fr;
    height: 1fr;
    background: $surface;
}

/* --- Terminal Panel --- */

#terminal-panel {
    height: auto;
    min-height: 1;
}

#terminal-panel #terminal-tab-bar {
    height: 1;
    background: $boost;
    color: $text;
    padding: 0 1;
}

#terminal-panel #terminal-switcher {
    height: 1fr;
}

#terminal-panel #terminal-status-line {
    height: 1;
    background: $surface;
    color: $text-muted;
    padding: 0 1;
}

#app-layout {
    height: 1fr;
}
